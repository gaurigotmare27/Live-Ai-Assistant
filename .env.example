# FastAPI Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Google Gemini API Key
# Get one from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Web Search API Keys (Specify the one used in config/agent_config.yaml)
# If using Tavily (https://tavily.com/):
TAVILY_API_KEY=your_tavily_api_key_here

# If using Google Custom Search:
GOOGLE_SEARCH_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Database Configuration (SQLite default)
DATABASE_URL=sqlite:///./live_assistant.db
